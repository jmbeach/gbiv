{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/spray-bottle.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "file_path=$(cat | jq -r '.file_path') && [[ \"$file_path\" == *.rs ]] && cargo fmt -- \"$file_path\" || true"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "file_path=$(cat | jq -r '.file_path') && [[ \"$file_path\" == *.rs ]] && cargo fmt -- \"$file_path\" || true"
          }
        ]
      }
    ]
  }
}
